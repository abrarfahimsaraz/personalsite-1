{
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/((?!.*\\.(?:xml|txt|ico|png|jpg|jpeg|gif|svg|webp|pdf|css|js|json|woff|woff2|ttf|eot)$).*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ]
}
